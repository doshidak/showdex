{
  "name": "showdex",
  "version": "1.3.0",
  "description": "Pokémon Showdown extension that harnesses the power of parabolic calculus to strategically extract your opponents' Elo.",
  "author": "Keith Choison <keith@tize.io>",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/doshidak/showdex",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/doshidak/showdex.git"
  },
  "bugs": {
    "url": "https://github.com/doshidak/showdex/issues"
  },
  "private": true,
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^10.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "type": "module",
  "scripts": {
    "patch-ghooks": "./scripts/patch-ghooks.sh",
    "commit": "./node_modules/cz-customizable/standalone.js",
    "cm": "pnpm commit",
    "cz": "pnpm commit",
    "postinstall": "pnpm patch-ghooks",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "update:bldb": "pnpm browserslist --update-db",
    "cache:purge": "pnpm cache:purge:swc; pnpm cache:purge:webpack",
    "cache:purge:swc": "rimraf ./node_modules/.cache/swc",
    "cache:purge:webpack": "rimraf ./node_modules/.cache/webpack",
    "clean": "pnpm clean:dev; pnpm clean:prod; pnpm cache:purge",
    "clean:dev": "pnpm clean:dev:chrome; pnpm clean:dev:firefox; pnpm clean:dev:standalone",
    "clean:dev:chrome": "rimraf ./build/chrome",
    "clean:dev:firefox": "rimraf ./build/firefox ./build/*.firefox.xpi",
    "clean:dev:standalone": "rimraf ./build/standalone",
    "clean:prod": "pnpm clean:prod:chrome; pnpm clean:prod:firefox; pnpm clean:prod:standalone",
    "clean:prod:chrome": "rimraf ./dist/chrome ./dist/*.chrome.zip ./dist/*.chrome.html",
    "clean:prod:firefox": "rimraf ./dist/firefox ./dist/*.firefox.xpi ./dist/*.firefox.html",
    "clean:prod:standalone": "rimraf ./dist/standalone ./dist/*.standalone.html",
    "dev": "pnpm dev:chrome",
    "dev:nc": "pnpm cache:purge && cross-env DEV_WEBPACK_CACHE_ENABLED=false pnpm dev",
    "dev:sc": "cross-env DEV_SPRING_CLEANING=true pnpm dev",
    "dev:re": "pnpm cache:purge && pnpm dev",
    "dev:chrome": "pnpm clean:dev:chrome && cross-env NODE_ENV=development BUILD_TARGET=chrome node --conditions=development --trace-warnings ./scripts/dev",
    "dev:chrome:re": "pnpm cache:purge && pnpm dev:chrome",
    "dev:firefox": "pnpm clean:dev:firefox && cross-env NODE_ENV=development BUILD_TARGET=firefox node --conditions=development --trace-warnings ./scripts/dev",
    "dev:firefox:re": "pnpm cache:purge && pnpm dev:firefox",
    "dev:standalone": "pnpm clean:dev:standalone && cross-env NODE_ENV=development BUILD_TARGET=standalone node --conditions=development --trace-warnings ./scripts/dev",
    "dev:standalone:re": "pnpm cache:purge && pnpm dev:standalone",
    "build": "pnpm build:chrome && pnpm build:firefox",
    "build:fast": "cross-env PROD_ANALYZE_BUNDLES=false pnpm build",
    "build:re": "pnpm cache:purge && pnpm build",
    "build:chrome": "pnpm clean:prod:chrome && cross-env NODE_ENV=production BUILD_TARGET=chrome node --conditions=production ./scripts/build",
    "build:chrome:fast": "cross-env PROD_ANALYZE_BUNDLES=false pnpm build:chrome",
    "build:chrome:re": "pnpm cache:purge && pnpm build:chrome",
    "build:firefox": "pnpm clean:prod:firefox && cross-env NODE_ENV=production BUILD_TARGET=firefox node --conditions=production ./scripts/build",
    "build:firefox:fast": "cross-env PROD_ANALYZE_BUNDLES=false pnpm build:firefox",
    "build:firefox:re": "pnpm cache:purge && pnpm build:firefox",
    "build:standalone": "pnpm clean:prod:standalone && cross-env NODE_ENV=production BUILD_TARGET=standalone node --conditions=production ./scripts/build",
    "build:standalone:fast": "cross-env PROD_ANALYZE_BUNDLES=false pnpm build:standalone",
    "build:standalone:re": "pnpm cache:purge && pnpm build:standalone"
  },
  "config": {
    "cz-customizable": {
      "config": ".cz-config.cjs"
    },
    "ghooks": {
      "commit-msg": "npx cz-customizable-ghooks $2"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/react": "^0.42.0",
    "@react-aria/button": "^3.8.0",
    "@react-aria/switch": "^3.5.2",
    "@react-aria/textfield": "^3.10.0",
    "@react-aria/visually-hidden": "^3.8.2",
    "@react-hook/size": "^2.1.2",
    "@react-spring/web": "^9.7.3",
    "@react-stately/toggle": "^3.6.0",
    "@reduxjs/toolkit": "^1.9.5",
    "@smogon/calc": "^0.11.0",
    "@tippyjs/react": "^4.2.6",
    "@use-gesture/react": "^10.2.27",
    "base-64": "^1.0.0",
    "chalk": "^5.3.0",
    "change-case": "^5.4.4",
    "classnames": "^2.3.2",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "final-form": "^4.20.9",
    "i18next": "^23.7.16",
    "i18next-browser-languagedetector": "^7.2.0",
    "i18next-intervalplural-postprocessor": "^3.0.0",
    "lexical": "^0.42.0",
    "lz-string": "^1.5.0",
    "prismjs": "^1.30.0",
    "qs": "^6.11.2",
    "react": "^18.3.1",
    "react-contexify": "^6.0.0",
    "react-dom": "^18.3.1",
    "react-final-form": "^6.5.9",
    "react-hotkeys-hook": "^5.2.4",
    "react-i18next": "^14.0.0",
    "react-inlinesvg": "^3.0.2",
    "react-redux": "^8.1.1",
    "react-select": "^5.8.0",
    "regexp.escape": "^2.0.1",
    "romans": "^3.1.0",
    "simplebar": "^6.2.5",
    "slugify": "^1.6.6",
    "ua-parser-js": "^2.0.9",
    "use-debouncy": "^5.1.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-types/textfield": "^3.7.2",
    "@swc/core": "^1.15.21",
    "@types/base-64": "^1.0.0",
    "@types/chrome": "^0.1.38",
    "@types/file-saver": "^2.0.7",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.5.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ua-parser-js": "^0.7.36",
    "@typescript-eslint/eslint-plugin": "8.58.0",
    "@typescript-eslint/parser": "8.58.0",
    "autoprefixer": "^10.4.14",
    "browserslist": "^4.21.9",
    "circular-dependency-plugin": "^5.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "cz-customizable": "^7.0.0",
    "cz-customizable-ghooks": "^2.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "file-loader": "^6.2.0",
    "ghooks": "^2.0.4",
    "glob": "^13.0.6",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.5.3",
    "postcss": "^8.4.26",
    "postcss-loader": "^8.2.1",
    "rimraf": "^6.1.3",
    "sass": "^1.63.6",
    "sass-loader": "^16.0.7",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "swc-loader": "^0.2.7",
    "terser-webpack-plugin": "^5.3.9",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "typescript-plugin-css-modules": "^5.0.1",
    "webpack": "^5.88.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-visualizer-plugin2": "^2.0.0",
    "zip-webpack-plugin": "^4.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core"
    ]
  }
}
